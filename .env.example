# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit it.
#
# Get these values by:
# 1. Visit https://dextrous.finance
# 2. Connect your wallet, sign the registration message
# 3. Generate an Orderly API key from inside the Dextrous interface
# 4. Copy the three values below

# Your Orderly account ID — a hex string starting with 0x
# This is derived from your wallet address + the dextrousfinance broker ID.
ORDERLY_ACCOUNT_ID=0x_paste_your_account_id_here

# Your Orderly API key — ed25519 format
ORDERLY_KEY=ed25519:paste_your_key_here

# Your Orderly API secret — ed25519 format
# WARNING: never share this. Anyone with it can place orders from your account.
ORDERLY_SECRET=ed25519:paste_your_secret_here

# Set to True while testing on testnet. False for mainnet (real money).
ORDERLY_TESTNET=True

# Optional: identifier for WebSocket connections. Any string.
WSS_ID=dextrousfinance-bot
